---
import Button from "../ui/Button.astro";
import { heroImages } from "../../data/heroImages";
---

<section class="hero-slider relative max-h-[390px] lg:max-h-full w-full max-w-[1440px] mx-auto aspect-[1440/900] overflow-hidden">
  {
    heroImages.map((image, index) => (
      <img
        src={image.src}
        alt="Bilder av ulike personer"
        class:list={[
          "hero-slide absolute inset-0 block h-full w-full object-cover transition-opacity duration-[2500ms]",
          index === 0 ? "opacity-100" : "opacity-0",
        ]}
      />
    ))
  }

  <div class="lg:absolute inset-0 z-0 bg-[linear-gradient(to_right,rgb(255_255_255_/_100%)_0%,rgb(255_255_255_/_75%)_10%,rgb(255_255_255_/_0%)_40%)]"></div>

  <div class="hidden lg:block absolute left-[32px] top-[65%] z-10 max-w-[450px] -translate-y-1/2 font-area text-heber-black">
    <h1 class="mb-5 text-2xl font-normal">Velg en rekrutterer som selv har vært i din verden</h1>

    <div class="flex flex-wrap gap-2">
      <Button href="/rekruttering" variant="yellow">Rekrutteringstjenester</Button>
      <Button href="/kontakt" variant="outline">Kontakt meg</Button>
    </div>
  </div>
</section>
<section class="flex lg:hidden justify-center p-10 mb-10 mt-2">
  <div class="block lg:hidden max-w-[450px] font-area text-heber-black">
    <h1 class="mb-5 text-2xl font-normal">Velg en rekrutterer som selv har vært i din verden</h1>

    <div class="flex flex-wrap gap-2">
      <Button href="/rekruttering" variant="yellow">Rekrutteringstjenester</Button>
      <Button href="/kontakt" variant="outline">Kontakt meg</Button>
    </div>
  </div>
</section>

<script>
  import { initHeroSlider } from "../../scripts/heroSlider";

  initHeroSlider(".hero-slider");
</script>
