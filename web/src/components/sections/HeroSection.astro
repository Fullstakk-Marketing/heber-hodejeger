---
type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props;
---



<section class="bg-heber-beige/30 py-28">
    <div class="flex flex-col max-w-[1440px] mx-auto p-10 items-center" >
        <h1 class="text-4xl font-medium mb-6" >{title}</h1>
        <p class="text-base max-w-[60ch] text-center font-regular mb-10" >{description}</p>
        <div class="flex flex-wrap gap-3 justify-center max-w-[600px]" >
            <slot />
        </div>
    </div>
</section>