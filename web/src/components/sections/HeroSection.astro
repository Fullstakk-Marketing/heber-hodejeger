---
type Props = {
  title: string;
  description?: string;
};

const { title, description } = Astro.props;
---



<section class="bg-heber-beige/30">
    <div class="max-w-1440 mx-auto" >
        <h1>{title}</h1>
        <p>{description}</p>
        <div class="flex wrap max-w-[600px]" >
            <slot />
        </div>
    </div>
</section>