---
import Button from "../ui/Button.astro";

const navLinks = [
  { href: "/rekruttering", label: "Rekruttering" },
  { href: "#", label: "Rådgivning" },
  { href: "#", label: "Kundehistorier" },
  { href: "#", label: "Om meg" },
  { href: "#", label: "Kontakt" },
];
---

<div class="lg:hidden" data-mobile-nav>
  <button
    type="button"
    aria-label="Åpne meny"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-mobile-nav-button
    class="absolute right-8 top-6 z-50 flex h-10 w-10 items-center justify-center"
  >
    <span class="sr-only">Åpne meny</span>

    <span class="relative block h-5 w-7">
      <span data-line-1 class="absolute left-0 block h-0.5 w-full -translate-y-2 bg-heber-black transition duration-300"></span>
      <span data-line-2 class="absolute left-0 block h-0.5 w-full -translate-y-1/2 bg-heber-black transition duration-300"></span>
      <span data-line-3 class="absolute left-0 top-1/6 block h-0.5 w-full translate-y-1 bg-heber-black transition duration-300"></span>
    </span>
  </button>

  <button
    type="button"
    aria-label="Lukk meny"
    data-mobile-nav-overlay
    class="pointer-events-none fixed inset-0 z-40 bg-black/30 opacity-0 transition duration-300"></button>

  <nav
    id="mobile-menu"
    aria-hidden="true"
    data-mobile-nav-panel
    class="fixed right-0 top-0 z-40 flex h-dvh w-[min(75vw,375px)] translate-x-full flex-col justify-center bg-heber-beige px-10 shadow-[-10px_0_25px_-15px_rgba(0,0,0,0.25)] transition duration-300"
  >
    <ul class="flex flex-col gap-10">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-2xl font-medium text-heber-black transition hover:opacity-80 active:underline" data-mobile-nav-link>
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <Button href="#" variant="oxblood">Ledige stillinger</Button>
      </li>
    </ul>
  </nav>
</div>

<script>
  import { initMobileNav } from "../../scripts/mobileNav";

  initMobileNav();
</script>
