---
type Props = {
  number: number | string;
  title: string;
  content: string;
  numberBgClass?: string;
  numberTextClass?: string;
};

const { number, title, content, numberBgClass = "bg-white/10", numberTextClass = "text-white" } = Astro.props;
---

<li class="list-none">
  <details class="group">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-full bg-heber-black px-5 py-4 text-white transition">
      <div class="flex min-w-0 items-center gap-4">
        <span class:list={["flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold", numberBgClass, numberTextClass]}>
          {number}
        </span>

        <h3 class="text-left text-base font-semibold">
          {title}
        </h3>
      </div>

      <span class="relative flex h-6 w-6 shrink-0 items-center justify-center">
        <span class="absolute text-2xl leading-none transition-opacity duration-200 group-open:opacity-0"> + </span>
        <span class="absolute text-2xl leading-none opacity-0 transition-opacity duration-200 group-open:opacity-100"> − </span>
      </span>
    </summary>

    <div class="mt-3 rounded-[28px] bg-heber-beige px-5 py-5 text-heber-black">
      <p>{content}</p>
    </div>
  </details>
</li>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
