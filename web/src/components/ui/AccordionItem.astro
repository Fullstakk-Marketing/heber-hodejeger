---
type Props = {
  number: number | string;
  title: string;
  numberBgColor?: string;
  numberTextColor?: string;
  numberBorderColor?: string;
};

const { number, title, numberBgColor = "bg-white/10", numberTextColor = "text-white", numberBorderColor = "border-white" } = Astro.props;
---

<li class="list-none">
  <details class="group">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-full bg-heber-oxblood px-3 py-3 text-white transition">
      <div class="flex min-w-0 items-center gap-4">
        <span
          class:list={[
            "flex h-10 w-10 shrink-0 items-center border border-1 justify-center rounded-full text-sm font-medium",
            numberBgColor,
            numberTextColor,
            numberBorderColor,
          ]}
        >
          {number}
        </span>

        <h3 class="text-left text-base font-medium">
          {title}
        </h3>
      </div>

      <span class="relative flex h-6 w-6 shrink-0 items-center justify-center">
        <span class="absolute text-2xl leading-none transition-opacity duration-200 group-open:opacity-0 mb-1 me-4"> + </span>
        <span class="absolute text-2xl leading-none opacity-0 transition-opacity duration-200 group-open:opacity-100 mb-1 me-4"> − </span>
      </span>
    </summary>

    <div class="mt-3 rounded-[28px] bg-heber-beige/30 border border-heber-beige px-5 py-5 text-heber-black">
      <h4 class="mb-2 font-semibold">{title}</h4>
      <slot />
    </div>
  </details>
</li>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
