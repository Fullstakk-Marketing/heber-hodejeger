---
//component imports
import MainLayout from "../../layouts/MainLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import SplitSection from "../../components/sections/SplitSection.astro";
import Button from "../../components/ui/Button.astro";
import image from "../../assets/images/images/am2.webp";
import Card from "../../components/ui/Card.astro";
import BannerCard from "../../components/sections/BannerCard.astro";
import CardsSection from "../../components/sections/CardsSection.astro";

import { heroContent } from "../../data/heroContent";

const { title, description } = heroContent.workshop;
---

<MainLayout title="Heber hodejeger | Foredrag og workshops">
  <HeroSection title={title} description={description}>
    <Button href="/hvorfor-velge-meg" variant="oxblood">Hvorfor velge meg?</Button>
    <Button href="/kundehistorier" variant="outline">Kundehistorier</Button>
  </HeroSection>
  <SplitSection>
    <div slot="left">
      <h2 class="text-3xl mb-6">Hvordan lykkes med rekruttering</h2>
      <p class="text-base">
        Det er mange feller å gå i når man skal rekruttere: Hen er den smarteste kandidaten. Men får hen tilstrekkelig med utfordringer til stillingen din? Hen
        er den mest utadvendte og sjarmerende. Men er det viktig for å lykkes i stillingen din? Hen er den som har lavest lønnsnivå. Men er det lurt å spekulere
        i å lønne lavt? Hen er den som ligner mest på hen som slutter. Men ansetter du for dine nåværende eller fremtidige behov?
        <br />
        <br />

        Så har du bekreftelsesfella – du stiller referansene ja-nei spørsmål som bekrefter det du tror du vet om kandidaten.

        <br />
        <br />

        Ring meg for en uforpliktende prat om du vil ha et foredrag eller en workshop om hvordan unngå de vanligste fellene – og dermed øke sjansene for en
        vellykket rekruttering.
      </p>
    </div>
    <div slot="right">
      <div>
        <img src={image.src} alt="Bilde av Anne Marit Heber Nærby" />
      </div>
    </div>
  </SplitSection>
  <BannerCard
    title="Rekruttering"
    description="Rekrutteringsbehov kan variere. La meg gjerne ta hånd om prosessen fra A-Å, eller kun deler av den. Jeg er fleksibel."
    bgColor="bg-heber-beige/30"
  >
    <Button href="/rekruttering" variant="oxblood">Rekrutteringstjenester</Button>
  </BannerCard>

  <CardsSection>
  
      <Card
        bgColor="bg-white"
        title="Hvorfor velge meg?"
        description="Velg en rekrutterer som selv har vært i din verden."
        href="hvorfor-velge-meg"
        buttonText="Les mer"
      />

   
      <Card
        bgColor="bg-white"
        title="Om meg"
        description="Jeg som står bak Heber hodejeger er Anne Marit Heber Nærby. Jeg har over 20 års erfaring fra rekruttering."
        href="/om-meg"
        buttonText="Les mer"
      />


      <Card
        bgColor="bg-white"
        title="Kundehistorier"
        href="/kundehistorier"
        description="Jeg har vært så heldig å fått hjelpe et bredt spekter av organisasjoner med rekrutteringer av både ledere og spesialister."
        buttonText="Se mer"
      />

  </CardsSection>
</MainLayout>
