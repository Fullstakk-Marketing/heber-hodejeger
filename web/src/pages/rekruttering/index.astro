---
//component imports
import MainLayout from "../../layouts/MainLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import SingleSection from "../../components/sections/SingleSection.astro";
import AccordionItem from "../../components/ui/AccordionItem.astro";

//ui and data imports
import Button from "../../components/ui/Button.astro";
import { heroContent } from "../../data/heroContent";

const accordionItems = [
  {
    number: "01",
    title: "Recruitment",
    content: "We help you find the right candidate.",
    numberBgClass: "bg-heber-yellow",
    numberTextClass: "text-heber-black",
  },
  {
    number: "02",
    title: "Advisory",
    content: "We provide strategic advice.",
    numberBgClass: "bg-heber-beige",
    numberTextClass: "text-heber-black",
  },
  {
    number: "03",
    title: "Workshop",
    content: "We run workshops for teams and leaders.",
    numberBgClass: "bg-heber-velvet",
    numberTextClass: "text-white",
  },
];
---

<MainLayout title="my title for this website" title="my description for this website">
  <HeroSection title={heroContent.rekruttering.title} description={heroContent.rekruttering.description}>
    <Button href="/kontakt" variant="oxblood">Kontakt meg</Button>
  </HeroSection>
  <SingleSection>
    <h2 class="text-3xl mb-6">Fullstendig prosess med kandidatsøk</h2>
    <p>
      Nedenfor beskrives en fullstendig prosess med kandidatsøk. Men, jeg er fleksibel, så dette kan også fungere som en a la carte meny, der du kan plukke det
      du har behov for. Noen alternativer skisseres lengre ned. Ta kontakt om ditt behov ikke er beskrevet her, så finner vi en løsning.
      <br />
      <br />
      <span class="font-medium">Trinnene i prosessen vil være som følger:</span>
    </p>
    <ul>
      <ol class="flex flex-col gap-4">
        {
          accordionItems.map((item) => (
            <AccordionItem
              number={item.number}
              title={item.title}
              content={item.content}
              numberBgClass={item.numberBgClass}
              numberTextClass={item.numberTextClass}
            />
          ))
        }
      </ol>
    </ul>
  </SingleSection>
</MainLayout>
